{
  "manifest_version": 3,
  "name": "DARFIN Browser Integration",
  "version": "1.1",
  "description": "Send downloads to DARFIN Download Manager",
  "browser_specific_settings": {
    "gecko": {
      "id": "darfin-extension@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "downloads",
    "storage",
    "contextMenus",
    "cookies",
    "activeTab",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
