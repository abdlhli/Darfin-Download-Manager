{
  "manifest_version": 3,
  "name": "DARFIN Browser Integration",
  "version": "1.0",
  "description": "Send downloads to DARFIN Download Manager",
  "browser_specific_settings": {
    "gecko": {
      "id": "darfin-extension@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html"
  }
}
