{
  "manifest_version": 3,
  "name": "DARFIN Browser Integration",
  "version": "1.0",
  "description": "Send downloads to DARFIN Download Manager",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
